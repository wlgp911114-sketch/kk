rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "wlgp911114@gmail.com");
    }

    // Participants: Anyone can create, only admin can read/update/delete
    match /participants/{participantId} {
      allow create: if true; // Publicly accessible for event participation
      allow read, update, delete: if isAdmin();
    }

    // Quiz Questions: Anyone can read, only admin can write
    match /quiz_questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CMS Content: Anyone can read, only admin can write
    match /cms_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings: Anyone can read, only admin can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User profiles (for role management)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
